{
  "name": "mcp-tool-card-summary",
  "version": "0.1.0",
  "description": "Fleet-analyze a directory of MCP Tool Cards (mcp-tool-card-spec). Counts by side-effect class, PII/secrets exposure, reversibility, human-approval-required; surfaces approval gaps (destructive tools missing human_approval_required: true). Library + CLI.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/mcp-tool-card-summary"
  },
  "keywords": [
    "mcp",
    "tool-card",
    "model-context-protocol",
    "governance",
    "ai-governance",
    "safety",
    "tool-governance",
    "typescript"
  ],
  "bin": {
    "mcp-tool-card-summary": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/cards --format summary",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
